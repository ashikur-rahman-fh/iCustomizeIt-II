{
  "name": "@i-customize-it/frontend-main",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "brand:hash": "node ../../infra/scripts/build/hash-brand-assets.mjs frontend-main",
    "prebuild": "pnpm run brand:hash",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "predev": "pnpm run brand:hash",
    "pretest": "pnpm run brand:hash && next typegen",
    "pretypecheck": "pnpm run brand:hash",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@i-customize-it/shared": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^25.0.1",
    "msw": "^2.6.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.6"
  }
}
